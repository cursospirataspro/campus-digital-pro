{
  "name": "reproductor-cursos",
  "version": "2.0.0",
  "description": "Plataforma DRM: HLS cifrado, marca de agua forense, almacenamiento B2",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "prod": "pm2 start ecosystem.config.js --env production",
    "stop": "pm2 stop reproductor",
    "restart": "pm2 restart reproductor",
    "reload": "pm2 reload reproductor",
    "logs": "pm2 logs reproductor",
    "monitor": "pm2 monit",
    "process-video": "node hls-processor.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "fluent-ffmpeg": "^2.1.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "uuid": "^9.0.1"
  }
}

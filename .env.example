# ============================================================
#  VARIABLES DE ENTORNO — copiar a .env para desarrollo local
#  En Render/Railway configurar directamente en el dashboard
# ============================================================

# ------- Servidor -------
PORT=3000
NODE_ENV=production
PUBLIC_URL=https://TU-URL.onrender.com

# ------- Modo local (videos en ./public/hls/) -------
LOCAL_MODE=true

# ------- JWT (genera con: openssl rand -hex 64) -------
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRET_LARGO_Y_ALEATORIO
JWT_EXPIRES_IN=2h
MEDIA_TOKEN_TTL=300

# ------- Administrador -------
ADMIN_USER=tu@email.com
ADMIN_PASS=TU_HASH_BCRYPT_O_PBKDF2

# ------- Backblaze B2 (dejar vacío si LOCAL_MODE=true) -------
B2_ENDPOINT=
B2_REGION=
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=

B2_BUCKET=tu-nombre-de-bucket
B2_BUCKET_IS_PRIVATE=true

# ------- Claves AES: almacén local (puede migrarse a KMS/Vault) -------
# Ruta al archivo JSON donde se guardan las claves de cifrado HLS
KEYS_STORE_PATH=./data/keys.json

# ------- Marca de agua forense -------
# Ruta al registro de entregas (puede migrarse a base de datos)
WATERMARK_LOG_PATH=./data/watermark-log.json

# ------- DRM Widevine (EZDRM — opcional, para Android/Chrome) -------
# Registrarse en: https://www.ezdrm.com
WIDEVINE_ENDPOINT=https://widevine-license.ezdrm.com/proxy
WIDEVINE_USERNAME=
WIDEVINE_PASSWORD=

# ------- DRM FairPlay (EZDRM — opcional, para iOS/Safari) -------
FAIRPLAY_ASK=                   # Application Secret Key (hex)
FAIRPLAY_CERT_PATH=./data/fairplay.cer

# ------- Administración -------
# Credenciales del administrador (para el panel y la API de subida)
ADMIN_USER=admin
ADMIN_PASS=CAMBIA_ESTO_POR_UNA_CONTRASEÑA_SEGURA
